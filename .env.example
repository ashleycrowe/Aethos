VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_MICROSOFT_CLIENT_ID=
# Azure app registration must be Multitenant. The app uses /organizations authority.
# Do not set or require a customer tenant ID for self-serve login.
VITE_API_BASE_URL=/api
VITE_DEMO_MODE=false
API_BASE_URL=http://localhost:3000

# Backend-only secrets. Never expose these with a VITE_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
